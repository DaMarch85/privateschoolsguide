---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import BathSideNav from '../../components/BathSideNav.astro';
import SchoolSquareCard from '../../components/SchoolSquareCard.astro';
import { supabase } from '../../lib/supabase';

type SchoolRow = {
  id: string | number;
  slug: string;
  name: string;
  phase: string | null;
  gender: string | null;
  age_min: number | null;
  age_max: number | null;
  day_boarding: string | null;
  description: string | null;
  latitude: number | null;
  longitude: number | null;
};

const fallbackMetaTitle = 'Bath private schools | The Private School Guide';
const fallbackMetaDescription =
  'Independent guide to Bath private schools. Compare schools, review fees and bursaries, explore open days, and use the map to narrow your shortlist.';

const { data: location, error: locationError } = await supabase
  .from('locations')
  .select('*')
  .eq('slug', 'bath')
  .single();

if (locationError || !location) {
  throw new Error(`Could not load Bath location from Supabase: ${locationError?.message || 'No location found'}`);
}

const { data: locationSchools, error: locationSchoolsError } = await supabase
  .from('location_schools')
  .select('school_id, sort_order')
  .eq('location_id', location.id)
  .order('sort_order', { ascending: true });

if (locationSchoolsError) {
  throw new Error(`Could not load Bath school links from Supabase: ${locationSchoolsError.message}`);
}

const schoolIds = (locationSchools || []).map((row) => row.school_id);

const { data: schoolsRaw, error: schoolsError } = await supabase
  .from('schools')
  .select('id, slug, name, phase, gender, age_min, age_max, day_boarding, description, latitude, longitude')
  .in('id', schoolIds);

if (schoolsError) {
  throw new Error(`Could not load Bath schools from Supabase: ${schoolsError.message}`);
}

const schoolMap = new Map((schoolsRaw || []).map((school) => [String(school.id), school as SchoolRow]));

const schools = (locationSchools || [])
  .map((link) => schoolMap.get(String(link.school_id)))
  .filter(Boolean) as SchoolRow[];

function getPhaseLabel(school: SchoolRow) {
  const phase = (school.phase || '').toLowerCase();

  if (phase.includes('all')) return 'All-through school';
  if (phase.includes('prep') || phase.includes('junior') || (school.age_max !== null && school.age_max <= 11)) return 'Prep school';
  return 'Senior school';
}

function getMapType(school: SchoolRow) {
  const phase = (school.phase || '').toLowerCase();

  if (phase.includes('all')) return 'allthrough';
  if (phase.includes('prep') || phase.includes('junior') || (school.age_max !== null && school.age_max <= 11)) return 'junior';
  return 'senior';
}

function getGenderLabel(gender: string | null) {
  const value = (gender || '').toLowerCase();
  if (value.includes('girl')) return 'Girls';
  if (value.includes('boy')) return 'Boys';
  return 'Co-ed';
}

function getFormatLabel(dayBoarding: string | null) {
  if (!dayBoarding) return 'Day';
  return dayBoarding
    .replace(/_/g, ' ')
    .replace(/\bday boarding\b/i, 'Day & boarding')
    .replace(/\bboarding and day\b/i, 'Day & boarding')
    .replace(/\bday and boarding\b/i, 'Day & boarding')
    .replace(/\bfull boarding\b/i, 'Full boarding')
    .replace(/\bweekly boarding\b/i, 'Weekly boarding')
    .replace(/\bday\b/i, 'Day');
}

function getAgeLabel(ageMin: number | null, ageMax: number | null) {
  if (ageMin !== null && ageMax !== null) return `Ages ${ageMin}–${ageMax}`;
  if (ageMin !== null) return `Ages ${ageMin}+`;
  if (ageMax !== null) return `Up to age ${ageMax}`;
  return 'Age range to be confirmed';
}

const schoolCards = schools.map((school) => ({
  slug: school.slug,
  name: school.name,
  href: `/bath/schools/${school.slug}/`,
  cardClass: `school-square-card school-square-card--${getMapType(school)}`,
  texts: [
    getPhaseLabel(school),
    `${getGenderLabel(school.gender)} · ${getFormatLabel(school.day_boarding)}`,
    getAgeLabel(school.age_min, school.age_max)
  ]
}));

const mapSchools = schools
  .filter((school) => school.latitude !== null && school.longitude !== null)
  .map((school) => ({
    name: school.name,
    slug: `/bath/schools/${school.slug}/`,
    lat: school.latitude,
    lng: school.longitude,
    type: getMapType(school),
    note: `${getPhaseLabel(school)} · ${getGenderLabel(school.gender)} · ${getFormatLabel(school.day_boarding)} · ${getAgeLabel(school.age_min, school.age_max).replace(/^Ages /, 'Ages ')}`
  }));
---
<BaseLayout
  title={location.meta_title || fallbackMetaTitle}
  description={location.meta_description || fallbackMetaDescription}
  canonicalPath="/bath/"
  includeLeaflet={true}
  bodyClass="location-page"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/assets/css/styles.css" />
    <link rel="stylesheet" href="/assets/css/bath-refined.css" />
  </Fragment>

  <a class="skip-link" href="#main">Skip to content</a>
  <SiteHeader minimal={true} />

  <section class="location-hero" aria-labelledby="bath-hero-title">
    <img src="/assets/img/bath/bath-location-hero.jpg" alt="Bath skyline" />
    <div class="location-hero-copy">
      <h1 id="bath-hero-title" class="location-hero-title location-hero-title-single">
        <span>{location.hero_title || location.name}</span>
      </h1>
    </div>
  </section>

  <main id="main" class="page-shell">
    <div class="shell location-layout">
      <BathSideNav />

      <section class="location-main-column" aria-labelledby="bath-grid-title">
        <h2 id="bath-grid-title" class="location-grid-title">Bath school overview</h2>
        <div class="school-square-grid">
          {schoolCards.map((school) => (
            <SchoolSquareCard {...school} />
          ))}
        </div>
      </section>

      <aside class="location-map-panel">
        <div class="location-map-head">
          <p class="nav-kicker">Bath map</p>
          <h2>School locations</h2>
        </div>
        <div id="bath-location-map" class="bath-location-map" aria-label="Bath school map"></div>
      </aside>
    </div>
  </main>

  <SiteFooter />

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
  <script define:vars={{ schools: mapSchools }}>
    function initBathMap() {
      const mapTarget = document.getElementById('bath-location-map');
      if (!mapTarget || !window.L || !schools.length) return false;

      if (mapTarget.dataset.initialized === 'true') return true;
      mapTarget.dataset.initialized = 'true';

      const map = window.L.map(mapTarget, { zoomControl: true, scrollWheelZoom: false });

      window.L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 18,
        attribution: '© OpenStreetMap contributors'
      }).addTo(map);

      function icon(type) {
        return window.L.divIcon({
          className: 'school-map-icon',
          html: `<span class="school-map-marker ${type}"></span>`,
          iconSize: [16, 16],
          iconAnchor: [8, 8],
          popupAnchor: [0, -8]
        });
      }

      const markers = schools.map((school) => {
        const marker = window.L.marker([school.lat, school.lng], { icon: icon(school.type) });
        marker.bindPopup(
          `<div class="map-popup"><h3 class="map-popup-title">${school.name}</h3><p class="map-popup-meta">${school.note}</p><a class="map-popup-link" href="${school.slug}">View school</a></div>`
        );
        marker.addTo(map);
        return marker;
      });

      const group = window.L.featureGroup(markers);
      map.fitBounds(group.getBounds(), { padding: [28, 28], maxZoom: 11 });

      setTimeout(() => map.invalidateSize(), 300);
      return true;
    }

    function waitForLeaflet() {
      let attempts = 0;
      const timer = setInterval(() => {
        attempts += 1;
        if (initBathMap() || attempts > 20) clearInterval(timer);
      }, 250);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', waitForLeaflet);
    } else {
      waitForLeaflet();
    }
  </script>
</BaseLayout>