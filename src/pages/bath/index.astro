---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import BathSideNav from '../../components/BathSideNav.astro';
import SchoolSquareCard from '../../components/SchoolSquareCard.astro';
import bathLocation from '../../data/bath/location.json';
---
<BaseLayout
  title={bathLocation.metaTitle}
  description={bathLocation.metaDescription}
  canonicalPath={bathLocation.canonicalPath}
  includeLeaflet={true}
  bodyClass="location-page"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/assets/css/styles.css" />
    <link rel="stylesheet" href="/assets/css/bath-refined.css" />
  </Fragment>

  <a class="skip-link" href="#main">Skip to content</a>
  <SiteHeader minimal={true} />

  <section class="location-hero" aria-labelledby="bath-hero-title">
    <img src={bathLocation.heroImage} alt="Bath skyline" />
    <div class="location-hero-copy">
      <h1 id="bath-hero-title" class="location-hero-title location-hero-title-single"><span>Bath</span></h1>
    </div>
  </section>

  <main id="main" class="page-shell">
    <div class="shell location-layout">
      <BathSideNav />

      <section class="location-main-column" aria-labelledby="bath-grid-title">
        <h2 id="bath-grid-title" class="location-grid-title">Bath school overview</h2>
        <div class="school-square-grid">
          {bathLocation.schoolCards.map((school) => (
            <SchoolSquareCard {...school} href={`/bath/schools/${school.slug}/`} />
          ))}
        </div>
      </section>

      <aside class="location-map-panel">
        <div class="location-map-head">
          <p class="nav-kicker">Bath map</p>
          <h2>School locations</h2>
        </div>
        <div id="bath-location-map" class="bath-location-map" aria-label="Bath school map"></div>
      </aside>
    </div>
  </main>

  <SiteFooter />

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  <script define:vars={{ schools: bathLocation.mapSchools }}>
    const mapTarget = document.getElementById('bath-location-map');
    if (mapTarget && window.L) {
      const map = window.L.map(mapTarget, { zoomControl: true, scrollWheelZoom: false });
      window.L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 18, attribution: '© OpenStreetMap contributors' }).addTo(map);

      function icon(type) {
        return window.L.divIcon({
          className: 'school-map-icon',
          html: `<span class="school-map-marker ${type}"></span>`,
          iconSize: [16, 16],
          iconAnchor: [8, 8],
          popupAnchor: [0, -8]
        });
      }

      const markers = schools.map((school) => {
        const marker = window.L.marker([school.lat, school.lng], { icon: icon(school.type) });
        marker.bindPopup(`<div class="map-popup"><h3 class="map-popup-title">${school.name}</h3><p class="map-popup-meta">${school.note}</p><a class="map-popup-link" href="${school.slug}">View school</a></div>`);
        marker.addTo(map);
        return marker;
      });

      const group = window.L.featureGroup(markers);
      map.fitBounds(group.getBounds(), { padding: [28, 28], maxZoom: 11 });
    }
  </script>
</BaseLayout>
