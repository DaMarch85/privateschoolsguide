---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import bathLocation from '../../../data/bath/location.json';
import SchoolSquareCard from '../../../components/SchoolSquareCard.astro';
---
<BaseLayout
  title="Bath schools directory | The Private School Guide"
  description="Browse all Bath private school profiles in one place."
  canonicalPath="/bath/schools/"
  bodyClass="location-page"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/assets/css/styles.css" />
    <link rel="stylesheet" href="/assets/css/bath-refined.css" />
  </Fragment>

  <a class="skip-link" href="#main">Skip to content</a>
  <SiteHeader minimal={true} />

  <main id="main" class="page-shell">
    <div class="shell" style="padding-top: 3rem; padding-bottom: 4rem;">
      <div style="display:flex; gap:1rem; align-items:baseline; flex-wrap:wrap; margin-bottom:1.5rem;">
        <h1 style="margin:0;">Bath schools</h1>
        <a class="school-back-link" href="/bath/">← Back to Bath</a>
      </div>
      <div class="school-square-grid">
        {bathLocation.schoolCards.map((school) => (
          <SchoolSquareCard {...school} href={`/bath/schools/${school.slug}/`} />
        ))}
      </div>
    </div>
  </main>

  <SiteFooter />
</BaseLayout>
