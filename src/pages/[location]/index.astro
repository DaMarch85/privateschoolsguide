---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLocationDirectoryData } from "../../lib/directory";

const { location } = Astro.params;

if (!location) {
  throw new Error("Missing location slug.");
}

const pageData = await getLocationDirectoryData(location);

if (!pageData || !pageData.location) {
  return Astro.redirect("/404");
}

const { location: locationRecord, schools } = pageData;

const pageTitle =
  locationRecord.meta_title || `${locationRecord.name} Private Schools | Private School Guide`;

const pageDescription =
  locationRecord.meta_description ||
  `Browse private schools in ${locationRecord.name}, compare options, and explore school profiles.`;

const introText = locationRecord.intro_text || "";

const mapSchools = (schools || [])
  .filter((school) => school && school.latitude != null && school.longitude != null)
  .map((school) => ({
    name: school.name,
    slug: school.slug,
    locationSlug: locationRecord.slug,
    href: `/${locationRecord.slug}/schools/${school.slug}/`,
    addressLine1: school.address_line1 || "",
    latitude: school.latitude,
    longitude: school.longitude,
  }));
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main class="location-page">
    <section class="hero">
      <div class="container">
        <h1>{locationRecord.hero_title || `${locationRecord.name} Private Schools`}</h1>
        {introText && <p>{introText}</p>}
      </div>
    </section>

    <section class="map-section">
      <div class="container">
        <h2>Map of schools in {locationRecord.name}</h2>

        <div
          id="location-directory-map"
          data-directory-map
          data-map-data-id="location-map-data"
          data-empty-state-id="location-map-empty"
          style="height: 420px; width: 100%; border-radius: 12px; overflow: hidden;"
        ></div>

        <p id="location-map-empty" hidden>
          School locations are being added.
        </p>

        <script type="application/json" id="location-map-data">
          {JSON.stringify(mapSchools)}
        </script>
      </div>
    </section>

    <section class="schools-section">
      <div class="container">
        <h2>Schools in {locationRecord.name}</h2>

        {schools?.length ? (
          <div class="school-grid">
            {schools.map((school) => (
              <article class="school-card">
                <h3>
                  <a href={`/${locationRecord.slug}/schools/${school.slug}/`}>{school.name}</a>
                </h3>
                {school.address_line1 && <p>{school.address_line1}</p>}
              </article>
            ))}
          </div>
        ) : (
          <p>No schools found yet for this location.</p>
        )}
      </div>
    </section>
  </main>

  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />
  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
    defer
  ></script>
  <script defer src="/assets/js/location-pages.js"></script>
</BaseLayout>
