---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import LocationSideNav from '../../components/LocationSideNav.astro';
import SchoolSquareCard from '../../components/SchoolSquareCard.astro';
import { getLocationPaths, getLocationDirectoryData } from '../../lib/directory';

export async function getStaticPaths() {
  return await getLocationPaths();
}

const { location: locationSlug } = Astro.params;
if (!locationSlug) throw new Error('Missing location slug');

const { location, schoolCards, mapSchools } = await getLocationDirectoryData(locationSlug);
const fallbackMetaTitle = `${location.name} private schools | The Private School Guide`;
const fallbackMetaDescription = `Independent guide to ${location.name} private schools. Compare schools, review fees and bursaries, explore open days, and use the map to narrow your shortlist.`;
const heroImage = '/assets/img/bath/bath-location-hero.jpg';
---
<BaseLayout
  title={location.meta_title || fallbackMetaTitle}
  description={location.meta_description || fallbackMetaDescription}
  canonicalPath={`/${location.slug}/`}
  includeLeaflet={true}
  bodyClass="location-page"
  dataLocationSlug={location.slug}
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/assets/css/styles.css" />
    <link rel="stylesheet" href="/assets/css/bath-refined.css" />
  </Fragment>

  <a class="skip-link" href="#main">Skip to content</a>
  <SiteHeader minimal={true} />

  <section class="location-hero" aria-labelledby="location-hero-title">
    <img src={heroImage} alt={`${location.name} skyline`} />
    <div class="location-hero-copy">
      <h1 id="location-hero-title" class="location-hero-title location-hero-title-single">
        <span>{location.hero_title || location.name}</span>
      </h1>
    </div>
  </section>

  <main id="main" class="page-shell">
    <div class="shell location-layout">
      <LocationSideNav locationSlug={location.slug} locationName={location.name} showBathExtras={location.slug === 'bath'} />

      <section class="location-main-column" aria-labelledby="location-grid-title">
        <h2 id="location-grid-title" class="location-grid-title">{location.name} school overview</h2>
        {location.intro_text ? <p class="location-intro">{location.intro_text}</p> : null}
        <div class="school-square-grid">
          {schoolCards.map((school) => (
            <SchoolSquareCard {...school} />
          ))}
        </div>
      </section>

      <aside class="location-map-panel">
        <div class="location-map-head">
          <p class="nav-kicker">{location.name} map</p>
          <h2>School locations</h2>
        </div>
        <div
          id="location-directory-map"
          class="bath-location-map"
          aria-label={`${location.name} school map`}
          data-directory-map
          data-map-data-id="location-map-data"
          data-empty-state-id="location-map-empty"
        ></div>
        <p id="location-map-empty" hidden>School location pins are being updated.</p>
      </aside>
    </div>
  </main>

  <SiteFooter />

  <script type="application/json" id="location-map-data">{JSON.stringify(mapSchools)}</script>
  <script defer src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  <script defer src="/assets/js/location-pages.js"></script>
</BaseLayout>
