---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLocationDirectoryData } from "../lib/directory";

const [bathData, bristolData] = await Promise.all([
  getLocationDirectoryData("bath"),
  getLocationDirectoryData("bristol"),
]);

const locations = [bathData?.location, bristolData?.location].filter(Boolean);

const homeMapSchools = [bathData, bristolData]
  .filter(Boolean)
  .flatMap((entry) => {
    const locationRecord = entry.location;
    const schools = entry.schools || [];

    return schools
      .filter((school) => school && school.latitude != null && school.longitude != null)
      .map((school) => ({
        name: school.name,
        slug: school.slug,
        locationSlug: locationRecord.slug,
        href: `/${locationRecord.slug}/schools/${school.slug}/`,
        addressLine1: school.address_line1 || "",
        latitude: school.latitude,
        longitude: school.longitude,
      }));
  });

const pageTitle = "Private School Guide";
const pageDescription =
  "Compare independent schools, browse city pages, and explore private school profiles across the UK.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <main class="home-page">
    <section class="hero">
      <div class="container">
        <h1>Private School Guide</h1>
        <p>Find and compare private schools across the UK.</p>
      </div>
    </section>

    <section class="locations-section">
      <div class="container">
        <h2>Browse locations</h2>

        <div class="location-grid">
          {locations.map((location) => (
            <article class="location-card">
              <h3>
                <a href={`/${location.slug}/`}>{location.name}</a>
              </h3>
              {location.intro_text && <p>{location.intro_text}</p>}
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="map-section">
      <div class="container">
        <h2>School map</h2>

        <div
          id="homepage-directory-map"
          data-directory-map
          data-map-data-id="homepage-map-data"
          data-empty-state-id="homepage-map-empty"
          style="height: 460px; width: 100%; border-radius: 12px; overflow: hidden;"
        ></div>

        <p id="homepage-map-empty" hidden>
          School locations are being added.
        </p>

        <script type="application/json" id="homepage-map-data">
          {JSON.stringify(homeMapSchools)}
        </script>
      </div>
    </section>
  </main>

  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />
  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
    defer
  ></script>
  <script defer src="/assets/js/location-pages.js"></script>
</BaseLayout>
