---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import homeLocations from '../data/homeLocations.json';
import { getHomepageMapSchools, getLiveLocations } from '../lib/directory';

const liveLocations = await getLiveLocations();
const liveLocationHrefs = new Set(liveLocations.map((location) => `/${location.slug}/`));
const locations = homeLocations.map((location) => {
  if (liveLocationHrefs.has(location.href)) {
    return {
      ...location,
      isLive: true,
      state: 'Live now'
    };
  }

  return location;
});

const homeMapSchools = await getHomepageMapSchools();
---
<BaseLayout
  title="The Private School Guide"
  description="Find your location and move into the relevant private school guide."
  canonicalPath="/"
  includeLeaflet={true}
  bodyClass="home-minimal"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/assets/css/homepage.css" />
  </Fragment>

  <main id="main">
    <section aria-labelledby="home-title" class="home-hero">
      <video autoplay class="hero-video hero-video-desktop" loop muted playsinline poster="/assets/video/home-hero-poster.jpg" preload="metadata">
        <source src="/assets/video/home-hero-desktop.mp4" type="video/mp4" />
      </video>
      <video autoplay class="hero-video hero-video-mobile" loop muted playsinline poster="/assets/video/home-hero-mobile-poster.jpg" preload="metadata">
        <source src="/assets/video/home-hero-mobile.mp4" type="video/mp4" />
      </video>
      <div aria-hidden="true" class="hero-wash"></div>
      <div class="hero-centre shell">
        <h1 class="hero-title" id="home-title">
          <span>THE</span>
          <span>PRIVATE SCHOOL</span>
          <span>GUIDE</span>
        </h1>
      </div>
    </section>

    <section aria-labelledby="finder-title" class="home-finder shell">
      <div class="finder-grid">
        <div class="finder-panel finder-locations">
          <p class="section-kicker">Find a location</p>
          <h2 id="finder-title">Choose the guide you want.</h2>
          <label class="visually-hidden" for="location-search">Search locations</label>
          <input autocomplete="off" class="location-search" id="location-search" placeholder="Search locations" type="search" />
          <ul class="location-list" id="location-list">
            {locations.map((location) => (
              <li>
                <a class:list={["location-link", location.isLive && "is-live"]} data-location-item data-name={location.name} href={location.href}>
                  <span class="location-name">{location.name}</span>
                  <span class="location-state">{location.state}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="finder-panel finder-map-panel">
          <div class="finder-map-head">
            <div>
              <p class="section-kicker">Current live schools</p>
              <h2>School map</h2>
            </div>
          </div>
          <div
            aria-label="Private school map"
            class="homepage-map"
            id="homepage-map"
            data-directory-map
            data-map-data-id="homepage-map-data"
            data-empty-state-id="homepage-map-empty"
          ></div>
          <p id="homepage-map-empty" hidden>School locations are being updated.</p>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter full={true} />

  <script type="application/json" id="homepage-map-data">{JSON.stringify(homeMapSchools)}</script>
  <script defer src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  <script defer src="/assets/js/homepage.js?v=20260314b"></script>
  <script defer src="/assets/js/location-pages.js?v=20260314b"></script>
</BaseLayout>
