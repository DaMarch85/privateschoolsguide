---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import homeLocations from '../data/homeLocations.json';
import {
  getLiveLocations,
  getLocationDirectoryData,
  getAgeLabel,
  getFormatLabel,
  getGenderLabel,
  getPhaseLabel,
  toNumber
} from '../lib/directory';

type HomeLocationItem = (typeof homeLocations)[number];

type HomeMapSchool = {
  name: string;
  href: string;
  lat: number;
  lng: number;
  type: string;
  note: string;
};

const BATH_COORDINATE_FALLBACKS: Record<string, { lat: number; lng: number }> = {
  'king-edwards-school': { lat: 51.386488, lng: -2.343663 },
  'kingswood-school': { lat: 51.398883, lng: -2.370005 },
  'kingswood-preparatory-school': { lat: 51.397143, lng: -2.373238 },
  'prior-park-college': { lat: 51.364523, lng: -2.343082 },
  'paragon-school': { lat: 51.370494, lng: -2.355122 },
  'monkton-combe-school': { lat: 51.357305, lng: -2.326354 },
  'royal-high-school-bath-gdst': { lat: 51.397185, lng: -2.365419 },
  'bath-academy': { lat: 51.383903, lng: -2.363978 },
  'downside-school': { lat: 51.253899, lng: -2.495195 }
};

function resolveSchoolCoordinates(
  locationSlug: string,
  school: { slug: string; latitude: number | null; longitude: number | null }
) {
  const lat = toNumber(school.latitude);
  const lng = toNumber(school.longitude);

  if (lat !== null && lng !== null) {
    return { lat, lng };
  }

  if (locationSlug === 'bath') {
    return BATH_COORDINATE_FALLBACKS[school.slug] || null;
  }

  return null;
}

function getHomepageMarkerType(dayBoarding: string | null) {
  const value = String(dayBoarding || '').toLowerCase();
  if (value.includes('boarding')) return 'boarding';
  return 'day';
}

const liveLocations = await getLiveLocations();
const liveLocationHrefSet = new Set(liveLocations.map((location) => `/${location.slug}/`));

const locations: HomeLocationItem[] = homeLocations.map((location) => {
  if (liveLocationHrefSet.has(location.href)) {
    return {
      ...location,
      isLive: true,
      state: 'Live now'
    };
  }

  return location;
});

const liveLocationDirectoryData = await Promise.all(
  liveLocations.map(async (liveLocation) => {
    const directoryData = await getLocationDirectoryData(liveLocation.slug);
    return {
      location: directoryData.location,
      schools: directoryData.schools
    };
  })
);

const homeMapSchools: HomeMapSchool[] = liveLocationDirectoryData.flatMap(({ location, schools }) =>
  schools
    .map((school) => {
      const coordinates = resolveSchoolCoordinates(location.slug, school);
      if (!coordinates) return null;

      return {
        name: school.name,
        href: `/${location.slug}/schools/${school.slug}/`,
        lat: coordinates.lat,
        lng: coordinates.lng,
        type: getHomepageMarkerType(school.day_boarding),
        note: `${location.name} · ${getPhaseLabel(school.phase, school.age_max)} · ${getGenderLabel(school.gender)} · ${getFormatLabel(school.day_boarding)} · Ages ${getAgeLabel(school.age_min, school.age_max)}`
      };
    })
    .filter(Boolean) as HomeMapSchool[]
);
---
<BaseLayout
  title="The Private School Guide"
  description="Find your location and move into the relevant private school guide."
  canonicalPath="/"
  includeLeaflet={true}
  bodyClass="home-minimal"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/assets/css/homepage.css" />
  </Fragment>

  <main id="main">
    <section aria-labelledby="home-title" class="home-hero">
      <video autoplay class="hero-video hero-video-desktop" loop muted playsinline poster="/assets/video/home-hero-poster.jpg" preload="metadata">
        <source src="/assets/video/home-hero-desktop.mp4" type="video/mp4" />
      </video>
      <video autoplay class="hero-video hero-video-mobile" loop muted playsinline poster="/assets/video/home-hero-mobile-poster.jpg" preload="metadata">
        <source src="/assets/video/home-hero-mobile.mp4" type="video/mp4" />
      </video>
      <div aria-hidden="true" class="hero-wash"></div>
      <div class="hero-centre shell">
        <h1 class="hero-title" id="home-title">
          <span>THE</span>
          <span>PRIVATE SCHOOL</span>
          <span>GUIDE</span>
        </h1>
      </div>
    </section>

    <section aria-labelledby="finder-title" class="home-finder shell">
      <div class="finder-grid">
        <div class="finder-panel finder-locations">
          <p class="section-kicker">Find a location</p>
          <h2 id="finder-title">Choose the guide you want.</h2>
          <label class="visually-hidden" for="location-search">Search locations</label>
          <input autocomplete="off" class="location-search" id="location-search" placeholder="Search locations" type="search" />
          <ul class="location-list" id="location-list">
            {locations.map((location) => (
              <li>
                <a class:list={["location-link", location.isLive && "is-live"]} data-location-item data-name={location.name} href={location.href}>
                  <span class="location-name">{location.name}</span>
                  <span class="location-state">{location.state}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="finder-panel finder-map-panel">
          <div class="finder-map-head">
            <div>
              <p class="section-kicker">Current live schools</p>
              <h2>School map</h2>
            </div>
          </div>
          <div aria-label="Private school map" class="homepage-map" id="homepage-map"></div>
          <p id="homepage-map-empty" hidden>School locations are being updated.</p>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter full={true} />

  <script type="application/json" id="homepage-map-data">{JSON.stringify(homeMapSchools)}</script>
  <script defer src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  <script defer src="/assets/js/homepage.js?v=20260314d"></script>
</BaseLayout>
